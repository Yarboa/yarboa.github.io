{
  "name": "yarboa-blog",
  "version": "1.0.0",
  "description": "Yarboa's blog - migrated to Eleventy",
  "scripts": {
    "serve": "eleventy --serve --port=8080",
    "build": "eleventy",
    "debug": "DEBUG=Eleventy* eleventy",
    "lint": "markdownlint '_posts/**/*.md'",
    "lint:fix": "markdownlint '_posts/**/*.md' --fix",
    "setup-hooks": "git config core.hooksPath .githooks"
  },
  "keywords": [
    "blog",
    "eleventy"
  ],
  "author": "Yarboa",
  "license": "MIT",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "markdownlint-cli": "^0.48.0"
  }
}
